{
  "family": "ceyfi-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ceyfi-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ceyfi-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "ceyfi-backend",
      "image": "ACCOUNT_ID.dkr.ecr.ap-southeast-1.amazonaws.com/ceyfi-backend:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT", "value": "8000" },
        { "name": "PYTHONUNBUFFERED", "value": "1" },
        { "name": "USE_SEYLAN_REAL", "value": "false" },
        { "name": "CORS_ORIGINS", "value": "http://localhost:3000,https://seylan-hub1.vercel.app" }
      ],
      "secrets": [
        {
          "name": "GROQ_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:ceyfi/groq-api-key"
        },
        {
          "name": "ELEVENLABS_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:ceyfi/elevenlabs-api-key"
        },
        {
          "name": "TELEGRAM_BOT_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:ceyfi/telegram-bot-token"
        },
        {
          "name": "SUPABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:ceyfi/supabase-url"
        },
        {
          "name": "SUPABASE_SERVICE_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:ceyfi/supabase-service-key"
        },
        {
          "name": "PAYHERE_MERCHANT_ID",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:ceyfi/payhere-merchant-id"
        },
        {
          "name": "PAYHERE_SECRET",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:ACCOUNT_ID:secret:ceyfi/payhere-secret"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ceyfi-backend",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health/ready || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}

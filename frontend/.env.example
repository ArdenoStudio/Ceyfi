# CEYFI Frontend

# API backend (local dev)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Supabase (wallet realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site URL for OG metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://ceyfi-app.vercel.app

# MPGS Hosted Checkout
NEXT_PUBLIC_MPGS_HOST=test-seylan.mtf.gateway.mastercard.com

# Server-only: demo admin key for reset/metrics proxies (set in Vercel project env, NOT NEXT_PUBLIC)
# DEMO_ADMIN_KEY=
# DEMO_RESET_ENABLED=true   # kiosk/demo builds only — any logged-in persona can trigger reset when enabled

# Optional: enable Vercel Web Analytics (off by default)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=true

# E2E tests only — bypass login gate
# NEXT_PUBLIC_SKIP_AUTH=true

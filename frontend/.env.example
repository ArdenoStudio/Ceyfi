# CEYFI Frontend — powered by Seylan Bank

# API backend (local dev)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Supabase (wallet realtime)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site URL for OG metadata
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://seylan-hub.vercel.app

# MPGS Hosted Checkout
NEXT_PUBLIC_MPGS_HOST=test-seylan.mtf.gateway.mastercard.com

# Demo admin key (must match backend DEMO_ADMIN_KEY for reset/seed)
NEXT_PUBLIC_DEMO_ADMIN_KEY=ceyfi-demo-admin

# E2E tests only — bypass login gate
# NEXT_PUBLIC_SKIP_AUTH=true
